<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Relawan Nusantara - Platform Relawan & Donasi</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="/style.css">
</head>
<body class="">

    <!-- NAVBAR -->
    <nav class="navbar">
        <a href="/" class="nav-logo">Relawan Nusantara</a>
        <ul class="nav-menu">
            <li class="nav-item"><a href="/pendidikan">Pendidikan</a></li>
            <li class="nav-item"><a href="/lingkungan">Lingkungan</a></li>
            <li class="nav-item"><a href="/kesehatan">Kesehatan</a></li>
            <li class="nav-item"><a href="/sosial-kemanusiaan">Sosial & Kemanusiaan</a></li>
        </ul>
        <div class="nav-right">
            <% if (typeof user !== 'undefined' && user) { %>
                <!-- User sudah login - Tampilkan sapaan -->
                <div class="nav-user-greeting">
                    <i class="fas fa-user-circle"></i>
                    <span>Halo, <%= user.name %>!</span>
                </div>
                <a href="/logout" class="btn btn-logout nav-logout-btn">
                    <i class="fas fa-sign-out-alt"></i>
                    Logout
                </a>
            <% } else { %>
                <!-- User belum login - Tampilkan tombol Login -->
                <a href="/login" class="btn btn-secondary nav-login-btn">
                    <i class="fas fa-sign-in-alt"></i>
                    Login
                </a>
            <% } %>
        </div>
        <div class="hamburger">
            <div class="bar1"></div>
            <div class="bar2"></div>
            <div class="bar3"></div>
        </div>
    </nav>
