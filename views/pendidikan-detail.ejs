    <script>
        // Theme Toggle Functionality
        const themeToggleBtn = document.querySelector('.theme-switcher');
        const themeToggleDarkIcon = document.getElementById('theme-toggle-dark-icon');
        const themeToggleLightIcon = document.getElementById('theme-toggle-light-icon');

        const applyTheme = (isDark) => {
            if (isDark) {
                document.documentElement.classList.add('dark-mode');
                themeToggleLightIcon.classList.remove('hidden');
                themeToggleDarkIcon.classList.add('hidden');
                localStorage.setItem('color-theme', 'dark');
            } else {
                document.documentElement.classList.remove('dark-mode');
                themeToggleDarkIcon.classList.remove('hidden');
                themeToggleLightIcon.classList.add('hidden');
                localStorage.setItem('color-theme', 'light');
            }
        };

        const savedTheme = localStorage.getItem('color-theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const isInitialDark = savedTheme === 'dark' || (savedTheme === null && prefersDark);
        applyTheme(isInitialDark);

        if (themeToggleBtn) {
            themeToggleBtn.addEventListener('click', () => {
                const isCurrentlyDark = document.documentElement.classList.contains('dark-mode');
                applyTheme(!isCurrentlyDark);
            });
        }

        // Misi Button Functionality
        document.getElementById('btnAmbilMisi').addEventListener('click', function() {
            // 1. Ambil data koin dari EJS (Server)
            const rewardMisi = parseInt("<%= detail.reward %>");
            const namaMisi = "<%= detail.title %>";

            // 2. Ambil saldo koin sekarang dari LocalStorage
            let currentCoins = parseInt(localStorage.getItem('relawan_koin')) || 0;

            // 3. Tambahkan reward ke saldo
            let newBalance = currentCoins + rewardMisi;
            localStorage.setItem('relawan_koin', newBalance);

            // 4. Notifikasi
            alert(`Selamat! 🎉\nKamu berhasil mendaftar misi: ${namaMisi}\nReward +${rewardMisi} Koin telah ditambahkan.`);

            // 5. Redirect ke halaman pendidikan buat cek koin di navbar
            window.location.href = "/pendidikan";
        });
    </script>

</body>
