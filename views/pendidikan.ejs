        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { background-color: var(--bg); color: white; font-family: 'Plus Jakarta Sans', sans-serif; overflow-x: hidden; }
        
        .bg-wrapper { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -1; background: radial-gradient(circle at 50% 50%, #0a1120 0%, #010409 100%); }
        .particle { position: absolute; background: white; border-radius: 50%; opacity: 0.3; animation: float 20s infinite linear; }
        @keyframes float {
            0% { transform: translateY(100vh) scale(0); opacity: 0; }
            50% { opacity: 0.5; }
            100% { transform: translateY(-10vh) scale(1); opacity: 0; }
        }

        .navbar { display: flex; justify-content: space-between; align-items: center; padding: 20px 8%; position: sticky; top: 0; z-index: 1000; backdrop-filter: blur(25px); background: rgba(1, 4, 9, 0.7); border-bottom: 1px solid rgba(255,255,255,0.05); }
        .nav-logo { font-weight: 800; font-size: 1.5rem; background: linear-gradient(90deg, var(--primary), var(--secondary)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; text-decoration: none; }
        .nav-menu { display: flex; list-style: none; gap: 30px; }
        .nav-menu a { text-decoration: none; color: #8b949e; font-size: 0.9rem; font-weight: 600; transition: 0.4s; }
        .nav-menu a:hover, .nav-menu a.active { color: var(--primary); text-shadow: 0 0 15px var(--primary); }
        .koin-btn { background: rgba(255, 218, 68, 0.1); border: 1px solid var(--gold); padding: 8px 16px; border-radius: 12px; color: var(--gold); font-weight: 800; }
        
        .hero { text-align: center; padding: 120px 20px 60px; }
        .hero h1 { font-size: 4rem; font-weight: 800; margin-bottom: 20px; letter-spacing: -2px; }
        .hero span { background: linear-gradient(90deg, #fff, var(--primary), var(--secondary)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        .hero p { color: #8b949e; font-size: 1.1rem; max-width: 600px; margin: 0 auto; line-height: 1.8; }

        .container { max-width: 1200px; margin: 0 auto; padding-bottom: 100px; }
        .grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 35px; }
        
        .card { 
            background: var(--glass); border: 1px solid rgba(255,255,255,0.05); border-radius: 40px; padding: 50px; 
            display: flex; flex-direction: column; justify-content: space-between; position: relative; overflow: hidden; transition: 0.6s cubic-bezier(0.23, 1, 0.32, 1); 
        }
        .card:hover { transform: translateY(-15px); border-color: var(--primary); background: rgba(255, 255, 255, 0.07); box-shadow: 0 30px 60px rgba(0,0,0,0.5); }
        .card-glow { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: radial-gradient(circle at var(--x) var(--y), rgba(0, 242, 255, 0.15), transparent 50%); opacity: 0; transition: 0.3s; pointer-events: none; }
        .card:hover .card-glow { opacity: 1; }

        .icon-box { width: 60px; height: 60px; background: linear-gradient(135deg, var(--primary), var(--accent)); border-radius: 18px; display: flex; align-items: center; justify-content: center; font-size: 1.8rem; margin-bottom: 25px; box-shadow: 0 10px 20px rgba(0, 242, 255, 0.2); }
        .card h3 { font-size: 1.8rem; font-weight: 800; margin-bottom: 15px; }
        .card p { color: #8b949e; line-height: 1.6; margin-bottom: 30px; }

        .btn-misi { display: block; width: 100%; padding: 18px; border-radius: 18px; background: white; color: black; font-weight: 800; text-align: center; text-decoration: none; transition: 0.3s; }
        .btn-misi:hover { background: var(--primary); color: white; box-shadow: 0 0 20px var(--primary); }

        @media (max-width: 850px) { .grid { grid-template-columns: 1fr; } .hero h1 { font-size: 3rem; } }
    </style>
