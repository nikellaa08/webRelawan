<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Program Relawan Pendidikan - Relawan Nusantara</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="/style.css">
</head>
<body>

    <!-- NAVBAR -->
    <nav class="navbar">
        <div class="navbar-left">
            <a href="/" class="back-button">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24"><path d="M15.41 16.59L10.83 12l4.58-4.59L14 6l-6 6 6 6z" fill="currentColor"></path></svg>
                Kembali ke Beranda
            </a>
            <span class="nav-logo">Relawan Nusantara</span>
        </div>
        <ul class="nav-menu">
            <li class="nav-item"><a href="/pendidikan">Pendidikan</a></li>
            <li class="nav-item"><a href="/lingkungan">Lingkungan</a></li>
            <li class="nav-item"><a href="/kesehatan">Kesehatan</a></li>
            <li class="nav-item"><a href="/sosial-kemanusiaan">Sosial & Kemanusiaan</a></li>
        </ul>
        <div class="nav-right">
            <% if (typeof user !== 'undefined' && user) { %>
                <div class="nav-user-greeting">
                    <i class="fas fa-user-circle"></i>
                    <span>Halo, <%= user.name %>!</span>
                </div>
                <a href="/logout" class="btn btn-logout nav-logout-btn">
                    <i class="fas fa-sign-out-alt"></i>
                    Logout
                </a>
            <% } else { %>
                <a href="/login" class="btn btn-secondary nav-login-btn">
                    <i class="fas fa-sign-in-alt"></i>
                    Login
                </a>
            <% } %>
            <div class="theme-switcher">
                <svg id="theme-toggle-dark-icon" class="hidden" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path></svg>
                <svg id="theme-toggle-light-icon" class="hidden" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" fill-rule="evenodd" clip-rule="evenodd"></path></svg>
            </div>
        </div>
        <div class="hamburger">
            <div class="bar1"></div>
            <div class="bar2"></div>
            <div class="bar3"></div>
        </div>
    </nav>

    <style>
        main {
            margin-top: 80px;
            min-height: calc(100vh - 80px);
            overflow-y: auto;
            scroll-behavior: smooth;
        }

        main::-webkit-scrollbar {
            width: 8px;
        }

        main::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 10px;
        }

        main::-webkit-scrollbar-thumb {
            background: linear-gradient(180deg, #FF8C00, #FFD700);
            border-radius: 10px;
        }

        main::-webkit-scrollbar-thumb:hover {
            background: linear-gradient(180deg, #FFD700, #FFA726);
        }

        html {
            scroll-behavior: smooth;
        }

        /* Fade-in animation for cards */
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .program-list .event-card {
            animation: fadeInUp 0.6s ease-out;
            animation-fill-mode: both;
        }

        .program-list .event-card:nth-child(1) {
            animation-delay: 0.1s;
        }

        .program-list .event-card:nth-child(2) {
            animation-delay: 0.2s;
        }

        .program-list .event-card:nth-child(3) {
            animation-delay: 0.3s;
        }

        .program-list .event-card:nth-child(4) {
            animation-delay: 0.4s;
        }

        .program-list .event-card:hover {
            animation-play-state: paused;
        }
    </style>

    <main>
        <section class="section">
            <div class="container">
                <h2 class="section-title">Program Relawan Pendidikan</h2>
                <div class="section-subtitle">
                    <p>Pendidikan adalah kunci untuk masa depan yang lebih baik. Bersama Relawan Nusantara, mari berikan kesempatan pendidikan yang merata dan berkualitas bagi setiap anak bangsa.</p>
                    <p>Dari bimbingan belajar hingga penyediaan fasilitas, setiap kontribusimu adalah harapan. Mari gerakkan hati dan tangan untuk: <strong>mengajar, mendampingi, dan menginspirasi</strong>. Cerdaskan bangsa, sejahtera bersama!</p>
                </div>

                <%
                const educationPrograms = [
                    {
                        emoji: "🎒",
                        title: "Donasi Perlengkapan Sekolah",
                        slug: "donasi-perlengkapan",
                        cta: '"Satu pensil, satu buku, satu harapan. Donasikan perlengkapan sekolah untuk anak-anak yang membutuhkan."',
                        schedule: "Sesuai jadwal pengumpulan",
                        location: "Sekolah / Panti Asuhan",
                        target: "Anak-anak SD, SMP, SMA",
                        reward: "Koin + Lencana Donatur"
                    },
                    {
                        emoji: "🚌",
                        title: "Taman Baca Keliling",
                        slug: "taman-baca-keliling",
                        cta: '"Membawa jendela dunia lebih dekat kepada mereka. Mari bergerak bersama untuk menebar minat baca di pelosok negeri."',
                        schedule: "Setiap minggu / sesuai rute",
                        location: "Desa / Sekolah terpencil / Taman kota",
                        target: "Anak-anak SD – SMP-SMA/SMK",
                        reward: "Koin + Lencana Relawan Literasi"
                    },
                    {
                        emoji: "👩‍🏫",
                        title: "Bimbingan Belajar Gratis",
                        slug: "bimbingan-belajar",
                        cta: '"Bantu anak-anak meraih cita-cita. Bergabunglah sebagai pengajar atau pendamping bimbingan belajar gratis."',
                        schedule: "Sesuai jadwal yang ditentukan",
                        location: "Pusat Komunitas / Online",
                        target: "Matematika, Bahasa Indonesia, IPA, IPS",
                        reward: "Koin + Lencana Pengajar"
                    },
                    {
                        emoji: "🏗️",
                        title: "Renovasi Fasilitas Pendidikan",
                        slug: "renovasi-fasilitas",
                        cta: '"Lingkungan belajar yang nyaman, semangat belajar pun meningkat. Bantu wujudkan fasilitas pendidikan yang layak."',
                        schedule: "Sesuai jadwal yang ditentukan",
                        location: "Sekolah Rusak / Minim Fasilitas",
                        target: "Tukang Bangunan, Umum",
                        reward: "Koin + Lencana Pembangun"
                    }
                ];
                %>

                <div class="program-list grid">
                    <% educationPrograms.forEach(function(item, index) { %>
                    <div class="event-card">
                        <div class="card-body">
                            <h3 class="card-title"><%= item.emoji %> <%= item.title %></h3>
                            <p class="call-to-action"><%= item.cta %></p>

                            <div class="info-row">
                                <span class="icon-circle">📅</span>
                                <span class="info-label"><%= item.slug === 'donasi-perlengkapan' ? 'Batas Waktu:' : 'Jadwal Kegiatan:' %></span>
                                <span class="info-value"><%= item.schedule %></span>
                            </div>

                            <div class="info-row">
                                <span class="icon-circle">📍</span>
                                <span class="info-label"><%= item.slug === 'donasi-perlengkapan' ? 'Lokasi Penyaluran:' : 'Lokasi:' %></span>
                                <span class="info-value"><%= item.location %></span>
                            </div>

                            <div class="info-row">
                                <span class="icon-circle">👥</span>
                                <span class="info-label"><%= item.slug === 'donasi-perlengkapan' ? 'Tujuan Penerima:' : (item.slug === 'bimbingan-belajar' ? 'Mata Pelajaran:' : (item.slug === 'renovasi-fasilitas' ? 'Relawan:' : 'Peserta:')) %></span>
                                <span class="info-value"><%= item.target %></span>
                            </div>

                            <div class="info-row">
                                <span class="icon-circle">🏅</span>
                                <span class="info-label">Reward:</span>
                                <span class="info-value"><%= item.reward %></span>
                            </div>

                            <a href="/daftar-pendidikan/<%= item.slug %>" class="btn btn-primary btn-follow" style="margin-top: 1rem;">
                                Ikuti Sekarang
                            </a>
                        </div>
                    </div>
                    <% }); %>
                </div>

            </div>
        </section>
    </main>

    <!-- FOOTER -->
    <footer class="footer">
        <p>&copy; 2026 Relawan Nusantara. Semua Hak Dilindungi.</p>
    </footer>

    <script src="/script.js"></script>

</body>
</html>