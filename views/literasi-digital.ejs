<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Literasi Digital</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;800&display=swap" rel="stylesheet">
    <style>
        body { background: #010409; color: white; font-family: 'Plus Jakarta Sans', sans-serif; display: flex; justify-content: center; align-items: center; min-height: 100vh; margin: 0; }
        .card { background: #0d1117; border: 1px solid #30363d; border-radius: 30px; max-width: 450px; width: 90%; overflow: hidden; text-align: center; box-shadow: 0 20px 50px rgba(0,0,0,0.5); }
        .banner { background: linear-gradient(135deg, #0066ff, #00f2ff); padding: 40px; font-size: 5rem; }
        .content { padding: 30px; }
        .btn { background: #00f2ff; color: black; border: none; padding: 18px; width: 100%; border-radius: 15px; font-weight: 800; cursor: pointer; font-size: 1rem; transition: 0.3s; }
        .btn:hover { transform: scale(1.02); background: #fff; }
    </style>
</head>
<body>
    <div class="card">
        <div class="banner">💻</div>
        <div class="content">
            <h1 style="color: #00f2ff; margin: 0;">Literasi Digital</h1>
            <p style="color: #8b949e; margin: 15px 0;">Bantu remaja desa melek teknologi dan coding dasar.</p>
            <p style="font-size: 1.2rem;">🪙 <b>Reward: 350 Koin</b></p>
            <button class="btn" onclick="ambil(350, 'Literasi Digital')">Ambil Misi Sekarang</button>
            <br><br><a href="/pendidikan" style="color: #8b949e; text-decoration: none; font-size: 0.9rem;">← Kembali ke Daftar</a>
        </div>
    </div>
    <script>
        function ambil(r, n) {
            let koin = parseInt(localStorage.getItem('relawan_koin')) || 0;
            localStorage.setItem('relawan_koin', koin + r);
            alert('Berhasil! Misi ' + n + ' diambil. + ' + r + ' koin!');
            window.location.href = '/pendidikan';
        }
    </script>
</body>
</html>