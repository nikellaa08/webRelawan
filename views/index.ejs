                <p class="text-4xl font-extrabold text-emerald-500 mb-2 stat-number" data-target="1250">0</p>
                <p class="text-slate-500 font-medium uppercase text-xs tracking-widest">Total Relawan</p>
            </div>
            <div class="bg-white p-8 rounded-3xl shadow-sm border border-slate-100 text-center hover:shadow-md transition-shadow">
                <p class="text-4xl font-extrabold text-emerald-500 mb-2 stat-number" data-target="420">0</p>
                <p class="text-slate-500 font-medium uppercase text-xs tracking-widest">Program Terlaksana</p>
            </div>
            <div class="bg-white p-8 rounded-3xl shadow-sm border border-slate-100 text-center hover:shadow-md transition-shadow">
                <p class="text-4xl font-extrabold text-emerald-500 mb-2 stat-number" data-target="15000">0</p>
                <p class="text-slate-500 font-medium uppercase text-xs tracking-widest">Penerima Manfaat</p>
            </div>
            <div class="bg-white p-8 rounded-3xl shadow-sm border border-slate-100 text-center hover:shadow-md transition-shadow">
                <p class="text-4xl font-extrabold text-emerald-500 mb-2 stat-number" data-target="5000">0</p>
                <p class="text-slate-500 font-medium uppercase text-xs tracking-widest">Pohon Ditanam</p>
            </div>
        </div>
    </div>
</section>

<!-- 3. PROGRAM CATEGORIES (THE PILLARS) -->
<section id="program" class="py-24 bg-white">
    <div class="container mx-auto px-6">
        <div class="text-center max-w-3xl mx-auto mb-16">
            <h2 class="text-4xl font-extrabold text-slate-900 mb-4 tracking-tight leading-tight">Pilih Bidang Pengabdianmu</h2>
            <p class="text-lg text-slate-600">Sesuaikan minat dan keahlianmu dengan program yang tersedia. Setiap aksi memiliki arti.</p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto">
            <!-- Pendidikan -->
            <a href="/pendidikan" class="group bg-blue-50/50 p-10 rounded-3xl border border-transparent hover:border-blue-200 transition-all shadow-sm hover:shadow-md flex flex-col h-full">
                <div class="w-16 h-16 bg-blue-100 rounded-2xl flex items-center justify-center text-blue-600 mb-8 transition-transform group-hover:scale-110">
                    <i class="fas fa-book-open text-2xl"></i>
                </div>
                <h3 class="text-2xl font-bold text-slate-900 mb-4">Pendidikan</h3>
                <p class="text-slate-600 leading-relaxed mb-8 flex-grow">Membantu mengajar di panti asuhan, desa terpencil, atau mendonasikan perlengkapan sekolah.</p>
                <span class="text-blue-700 font-bold flex items-center gap-2 mt-auto">
                    Pelajari Selengkapnya <i class="fas fa-arrow-right text-sm"></i>
                </span>
            </a>
            
            <!-- Lingkungan -->
            <a href="/lingkungan" class="group bg-emerald-50/50 p-10 rounded-3xl border border-transparent hover:border-emerald-200 transition-all shadow-sm hover:shadow-md flex flex-col h-full">
                <div class="w-16 h-16 bg-emerald-100 rounded-2xl flex items-center justify-center text-emerald-600 mb-8 transition-transform group-hover:scale-110">
                    <i class="fas fa-leaf text-2xl"></i>
                </div>
                <h3 class="text-2xl font-bold text-slate-900 mb-4">Lingkungan</h3>
                <p class="text-slate-600 leading-relaxed mb-8 flex-grow">Penanaman mangrove, aksi bersih pantai, workshop daur ulang, dan kampanye pelestarian alam.</p>
                <span class="text-emerald-700 font-bold flex items-center gap-2 mt-auto">
                    Pelajari Selengkapnya <i class="fas fa-arrow-right text-sm"></i>
                </span>
            </a>
            
            <!-- Kesehatan -->
            <a href="/kesehatan" class="group bg-rose-50/50 p-10 rounded-3xl border border-transparent hover:border-rose-200 transition-all shadow-sm hover:shadow-md flex flex-col h-full">
                <div class="w-16 h-16 bg-rose-100 rounded-2xl flex items-center justify-center text-rose-600 mb-8 transition-transform group-hover:scale-110">
                    <i class="fas fa-heartbeat text-2xl"></i>
                </div>
                <h3 class="text-2xl font-bold text-slate-900 mb-4">Kesehatan</h3>
                <p class="text-slate-600 leading-relaxed mb-8 flex-grow">Layanan medis keliling, edukasi gizi, aksi donor darah, dan bantuan nutrisi bagi yang membutuhkan.</p>
                <span class="text-rose-700 font-bold flex items-center gap-2 mt-auto">
                    Pelajari Selengkapnya <i class="fas fa-arrow-right text-sm"></i>
                </span>
            </a>

            <!-- Sosial & Kemanusiaan -->
            <a href="/sosial-kemanusiaan" class="group bg-purple-50/50 p-10 rounded-3xl border border-transparent hover:border-purple-200 transition-all shadow-sm hover:shadow-md flex flex-col h-full">
                <div class="w-16 h-16 bg-purple-100 rounded-2xl flex items-center justify-center text-purple-600 mb-8 transition-transform group-hover:scale-110">
                    <i class="fas fa-hands-helping text-2xl"></i>
                </div>
                <h3 class="text-2xl font-bold text-slate-900 mb-4">Sosial & Kemanusiaan</h3>
                <p class="text-slate-600 leading-relaxed mb-8 flex-grow">Membantu penanganan bencana, penyaluran bantuan logistik untuk daerah terdampak, dan pendampingan psikososial.</p>
                <span class="text-purple-700 font-bold flex items-center gap-2 mt-auto">
                    Pelajari Selengkapnya <i class="fas fa-arrow-right text-sm"></i>
                </span>
            </a>
        </div>
    </div>
</section>

