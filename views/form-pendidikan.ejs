    <!-- Success Notification -->
    <div class="success-notification" id="successNotification">
        <div class="icon">🎉</div>
        <div class="message">
            <h3>Pendaftaran Berhasil!</h3>
            <p>Terima kasih telah mendaftar. Tim kami akan menghubungi Anda segera.</p>
        </div>
    </div>

    <script>
        // Progress Bar Logic
        function updateProgress(step) {
            const steps = document.querySelectorAll('.progress-step');
            const progressLine = document.getElementById('progressLine');

            steps.forEach((stepEl, index) => {
                const stepNum = index + 1;
                
                if (stepNum < step) {
                    // Completed step
                    stepEl.classList.remove('active');
                    stepEl.classList.add('completed');
                    stepEl.querySelector('.step-circle').innerHTML = '✓';
                } else if (stepNum === step) {
                    // Active step
                    stepEl.classList.add('active');
                    stepEl.classList.remove('completed');
                    stepEl.querySelector('.step-circle').textContent = stepNum;
                } else {
                    // Future step
                    stepEl.classList.remove('active', 'completed');
                    stepEl.querySelector('.step-circle').textContent = stepNum;
                }
            });

            // Update progress line width
            const progressWidth = ((step - 1) / (steps.length - 1)) * 100;
            progressLine.style.width = progressWidth + '%';
        }

        // Sticky Summary scroll effect
        const stickySummary = document.getElementById('stickySummary');

        window.addEventListener('scroll', () => {
            if (window.scrollY > 100) {
                stickySummary.classList.add('scrolled');
            } else {
                stickySummary.classList.remove('scrolled');
            }
        });

        // Tampilkan notifikasi sukses dari URL parameter dan redirect otomatis
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.get('success') === 'true') {
            const notification = document.getElementById('successNotification');
            notification.classList.add('show');

            // Hilangkan notifikasi setelah 3 detik
            setTimeout(() => {
                notification.classList.remove('show');
            }, 3000);

            // Redirect ke halaman pendidikan setelah 3 detik
            setTimeout(() => {
                window.location.href = '/pendidikan';
            }, 3000);
        }

        // Role Selection Logic for Taman Baca
        let selectedRole = null;

        function selectRole(role) {
            selectedRole = role;

            // Update visual selection
            document.querySelectorAll('#roleSelection .role-button').forEach(btn => {
                btn.classList.remove('selected');
            });
            document.querySelector(`#roleSelection .role-button[data-role="${role}"]`).classList.add('selected');

            // Set radio button
            document.getElementById(`role${role.charAt(0).toUpperCase() + role.slice(1)}`).checked = true;

            // Show/hide fields based on role
            if (role === 'relawan') {
                document.getElementById('relawanFields').classList.remove('hidden');
                document.getElementById('donaturFields').classList.add('hidden');

                // Make relawan fields required
                document.getElementById('jadwal').required = true;
                document.getElementById('lokasi').required = true;
                document.getElementById('keahlian').required = true;

                // Remove required from donatur fields
                document.getElementById('jenisDonasi').required = false;
                document.getElementById('jumlahDonasi').required = false;
            } else if (role === 'donatur') {
                document.getElementById('relawanFields').classList.add('hidden');
                document.getElementById('donaturFields').classList.remove('hidden');

                // Make donatur fields required
                document.getElementById('jenisDonasi').required = true;
                document.getElementById('jumlahDonasi').required = true;

                // Remove required from relawan fields
                document.getElementById('jadwal').required = false;
                document.getElementById('lokasi').required = false;
                document.getElementById('keahlian').required = false;
            }

            // Clear error
            document.getElementById('roleSelection').classList.remove('error');
            
            // Update progress
            checkFormProgress();
        }

        // Role Selection Logic for Renovasi
        let selectedRoleRenovasi = null;

        function selectRoleRenovasi(role) {
            selectedRoleRenovasi = role;

            // Update visual selection
            document.querySelectorAll('#roleSelectionRenovasi .role-button').forEach(btn => {
                btn.classList.remove('selected');
            });
            document.querySelector(`#roleSelectionRenovasi .role-button[data-role="${role}"]`).classList.add('selected');

            // Set radio button
            document.getElementById(`role${role.charAt(0).toUpperCase() + role.slice(1)}Renovasi`).checked = true;

            // Show/hide fields based on role
            if (role === 'relawan') {
                document.getElementById('relawanFieldsRenovasi').classList.remove('hidden');
                document.getElementById('donaturFieldsRenovasi').classList.add('hidden');

                // Make relawan fields required
                document.getElementById('jadwalRenovasi').required = true;
                document.getElementById('lokasiRenovasi').required = true;
                document.getElementById('keahlianRenovasi').required = true;
                document.getElementById('alasanRenovasi').required = true;

                // Remove required from donatur fields
                document.getElementById('jenisDonasiRenovasi').required = false;
                document.getElementById('jumlahDonasiRenovasi').required = false;
            } else if (role === 'donatur') {
                document.getElementById('relawanFieldsRenovasi').classList.add('hidden');
                document.getElementById('donaturFieldsRenovasi').classList.remove('hidden');

                // Make donatur fields required
                document.getElementById('jenisDonasiRenovasi').required = true;
                document.getElementById('jumlahDonasiRenovasi').required = true;

                // Remove required from relawan fields
                document.getElementById('jadwalRenovasi').required = false;
                document.getElementById('lokasiRenovasi').required = false;
                document.getElementById('keahlianRenovasi').required = false;
                document.getElementById('alasanRenovasi').required = false;
            }

            // Clear error
            document.getElementById('roleSelectionRenovasi').classList.remove('error');
            
            // Update progress
            checkFormProgress();
        }

        // Checkbox toggle for subjects
        function toggleCheckbox(element) {
            const checkbox = element.querySelector('input[type="checkbox"]');
            checkbox.checked = !checkbox.checked;
            element.classList.toggle('selected', checkbox.checked);
        }

        // Track form progress
        function checkFormProgress() {
            let step = 1;
            
            // Check Step 1: Data Diri (fullname, email, whatsapp)
            const fullname = document.getElementById('fullname');
            const email = document.getElementById('email');
            const whatsapp = document.getElementById('whatsapp');
            
            const step1Complete = fullname && fullname.value.trim() && 
                                  email && email.value.trim() && 
                                  whatsapp && whatsapp.value.trim();
            
            if (step1Complete) {
                step = 2;
                
                // Check Step 2: Data Program (depends on program type)
                const programType = '<%= program.type %>';
                const programSlug = '<%= program.slug %>';
                let step2Complete = false;
                
                if (programType === 'donasi') {
                    const jenisBarang = document.getElementById('jenisBarang');
                    const jumlahBarang = document.getElementById('jumlahBarang');
                    const metodePengiriman = document.getElementById('metodePengiriman');
                    step2Complete = jenisBarang && jenisBarang.value && 
                                    jumlahBarang && jumlahBarang.value && 
                                    metodePengiriman && metodePengiriman.value;
                } else if (programSlug === 'taman-baca-keliling') {
                    if (selectedRole === 'relawan') {
                        const jadwal = document.getElementById('jadwal');
                        const lokasi = document.getElementById('lokasi');
                        const keahlian = document.getElementById('keahlian');
                        step2Complete = jadwal && jadwal.value && 
                                        lokasi && lokasi.value.trim() && 
                                        keahlian && keahlian.value;
                    } else if (selectedRole === 'donatur') {
                        const jenisDonasi = document.getElementById('jenisDonasi');
                        const jumlahDonasi = document.getElementById('jumlahDonasi');
                        step2Complete = jenisDonasi && jenisDonasi.value && 
                                        jumlahDonasi && jumlahDonasi.value;
                    }
                } else if (programType === 'bimbel') {
                    const checkboxes = document.querySelectorAll('input[name="mataPelajaran"]:checked');
                    const jenjang = document.getElementById('jenjang');
                    step2Complete = checkboxes.length > 0 && jenjang && jenjang.value;
                } else if (programSlug === 'renovasi-fasilitas') {
                    if (selectedRoleRenovasi === 'relawan') {
                        const jadwal = document.getElementById('jadwalRenovasi');
                        const lokasi = document.getElementById('lokasiRenovasi');
                        const keahlian = document.getElementById('keahlianRenovasi');
                        const alasan = document.getElementById('alasanRenovasi');
                        step2Complete = jadwal && jadwal.value && 
                                        lokasi && lokasi.value.trim() && 
                                        keahlian && keahlian.value && 
                                        alasan && alasan.value.trim();
                    } else if (selectedRoleRenovasi === 'donatur') {
                        const jenisDonasi = document.getElementById('jenisDonasiRenovasi');
                        const jumlahDonasi = document.getElementById('jumlahDonasiRenovasi');
                        step2Complete = jenisDonasi && jenisDonasi.value && 
                                        jumlahDonasi && jumlahDonasi.value;
                    }
                }
                
                if (step2Complete) {
                    step = 3;
                }
            }
            
            updateProgress(step);
        }

        // Add event listeners to all form inputs to track progress
        document.addEventListener('DOMContentLoaded', function() {
            const formInputs = document.querySelectorAll('#registrationForm input, #registrationForm select, #registrationForm textarea');
            formInputs.forEach(input => {
                input.addEventListener('input', checkFormProgress);
                input.addEventListener('change', checkFormProgress);
            });
            
            // Initial check
            checkFormProgress();
        });

        // Form validation
        document.getElementById('registrationForm').addEventListener('submit', function(e) {
            let isValid = true;

            // Reset all errors
            document.querySelectorAll('.form-group').forEach(group => group.classList.remove('error'));
            const roleSelection = document.getElementById('roleSelection');
            if (roleSelection) roleSelection.classList.remove('error');
            const roleSelectionRenovasi = document.getElementById('roleSelectionRenovasi');
            if (roleSelectionRenovasi) roleSelectionRenovasi.classList.remove('error');

            // Validate common fields
            const fullname = document.getElementById('fullname');
            const email = document.getElementById('email');
            const whatsapp = document.getElementById('whatsapp');

            if (!fullname.value.trim()) {
                fullname.closest('.form-group').classList.add('error');
                isValid = false;
            }

            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            if (!emailRegex.test(email.value)) {
                email.closest('.form-group').classList.add('error');
                isValid = false;
            }

            if (!/^[0-9]{10,}$/.test(whatsapp.value)) {
                whatsapp.closest('.form-group').classList.add('error');
                isValid = false;
            }

            // Validate Donasi Perlengkapan
            const programType = '<%= program.type %>';
            const programSlug = '<%= program.slug %>';

            if (programType === 'donasi') {
                const jenisBarang = document.getElementById('jenisBarang');
                const jumlahBarang = document.getElementById('jumlahBarang');
                const metodePengiriman = document.getElementById('metodePengiriman');

                if (!jenisBarang.value) {
                    jenisBarang.closest('.form-group').classList.add('error');
                    isValid = false;
                }
                if (!jumlahBarang.value || parseInt(jumlahBarang.value) < 1) {
                    jumlahBarang.closest('.form-group').classList.add('error');
                    isValid = false;
                }
                if (!metodePengiriman.value) {
                    metodePengiriman.closest('.form-group').classList.add('error');
                    isValid = false;
                }
            }

            // Validate Taman Baca
            if (programSlug === 'taman-baca-keliling') {
                if (!selectedRole) {
                    document.getElementById('roleSelection').classList.add('error');
                    isValid = false;
                }

                if (selectedRole === 'relawan') {
                    const jadwal = document.getElementById('jadwal');
                    const lokasi = document.getElementById('lokasi');
                    const keahlian = document.getElementById('keahlian');

                    if (!jadwal.value) {
                        jadwal.closest('.form-group').classList.add('error');
                        isValid = false;
                    }
                    if (!lokasi.value.trim()) {
                        lokasi.closest('.form-group').classList.add('error');
                        isValid = false;
                    }
                    if (!keahlian.value) {
                        keahlian.closest('.form-group').classList.add('error');
                        isValid = false;
                    }
                }

                if (selectedRole === 'donatur') {
                    const jenisDonasi = document.getElementById('jenisDonasi');
                    const jumlahDonasi = document.getElementById('jumlahDonasi');

                    if (!jenisDonasi.value) {
                        jenisDonasi.closest('.form-group').classList.add('error');
                        isValid = false;
                    }
                    if (!jumlahDonasi.value || parseInt(jumlahDonasi.value) < 1) {
                        jumlahDonasi.closest('.form-group').classList.add('error');
                        isValid = false;
                    }
                }
            }

            // Validate Bimbingan Belajar
            if (programType === 'bimbel') {
                const checkboxes = document.querySelectorAll('input[name="mataPelajaran"]:checked');
                if (checkboxes.length === 0) {
                    document.querySelector('.checkbox-group').closest('.form-group').classList.add('error');
                    isValid = false;
                }

                const jenjang = document.getElementById('jenjang');
                if (!jenjang.value) {
                    jenjang.closest('.form-group').classList.add('error');
                    isValid = false;
                }
            }

            // Validate Renovasi
            if (programSlug === 'renovasi-fasilitas') {
                if (!selectedRoleRenovasi) {
                    document.getElementById('roleSelectionRenovasi').classList.add('error');
                    isValid = false;
                }

                if (selectedRoleRenovasi === 'relawan') {
                    const jadwal = document.getElementById('jadwalRenovasi');
                    const lokasi = document.getElementById('lokasiRenovasi');
                    const keahlian = document.getElementById('keahlianRenovasi');
                    const alasan = document.getElementById('alasanRenovasi');

                    if (!jadwal.value) {
                        jadwal.closest('.form-group').classList.add('error');
                        isValid = false;
                    }
                    if (!lokasi.value.trim()) {
                        lokasi.closest('.form-group').classList.add('error');
                        isValid = false;
                    }
                    if (!keahlian.value) {
                        keahlian.closest('.form-group').classList.add('error');
                        isValid = false;
                    }
                    if (!alasan.value.trim()) {
                        alasan.closest('.form-group').classList.add('error');
                        isValid = false;
                    }
                }

                if (selectedRoleRenovasi === 'donatur') {
                    const jenisDonasi = document.getElementById('jenisDonasiRenovasi');
                    const jumlahDonasi = document.getElementById('jumlahDonasiRenovasi');

                    if (!jenisDonasi.value) {
                        jenisDonasi.closest('.form-group').classList.add('error');
                        isValid = false;
                    }
                    if (!jumlahDonasi.value || parseInt(jumlahDonasi.value) < 1) {
                        jumlahDonasi.closest('.form-group').classList.add('error');
                        isValid = false;
                    }
                }
            }

            if (!isValid) {
                e.preventDefault();
                const firstError = document.querySelector('.form-group.error, .role-selection.error');
                if (firstError) {
                    firstError.scrollIntoView({ behavior: 'smooth', block: 'center' });
                }
            }
        });
    </script>

    <script src="/script.js"></script>
</body>
</html>
